# Example .env for local dev. Copy to .env and edit.

TTS_BACKEND=dummy
TTS_DEVICE=cpu
TTS_VOICES_DIR=./voices
TTS_MODEL_CACHE_DIR=./.cache/tts-gateway
TTS_DEFAULT_VOICE_ID=brand_default
TTS_MAX_TEXT_LENGTH=2000
TTS_DEFAULT_SAMPLE_RATE=24000
TTS_LOG_LEVEL=INFO

# Set to enable the /v1/voices admin endpoint (otherwise it returns 503).
# TTS_ADMIN_API_KEY=replace-me-with-a-long-random-token
